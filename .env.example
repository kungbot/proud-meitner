# JARVIS AI Assistant - Environment Variables Template
# Copy this file to .env and fill in your values.

# --- LLM Provider ---
# Options: "openai", "ollama", "mock"
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4o-mini

# Your OpenAI (or OpenRouter) API key.
# OpenRouter keys start with "sk-or-"
OPENAI_API_KEY=

# Ollama server URL (only needed if MODEL_PROVIDER=ollama)
OLLAMA_HOST=http://127.0.0.1:11434

# --- OCR ---
# Path to the Tesseract OCR executable (Windows default shown)
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# --- Voice ---
TTS_RATE=185
TTS_VOLUME=1.0

# --- Paths ---
# Root workspace directory JARVIS operates within
WORKSPACE_DIR=c:/Users/planm/Documents/antigravity/proud-meitner
# Application data / brain storage directory
APP_DATA_DIR=
